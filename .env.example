# IC Agent Configuration - Copy this to .env and fill in your values
# NEVER commit .env with real credentials to version control!

# Anthropic API Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
AGENT_MODEL=claude-sonnet-4-20250514
LLM_TIMEOUT_SECONDS=120

# Google Drive Configuration
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here
GOOGLE_DRIVE_FOLDER_IDS=folder-id-1,folder-id-2
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_OPPM_FOLDER_ID=optional-oppm-folder-id
GOOGLE_SRS_FOLDER_ID=optional-srs-folder-id
GOOGLE_REPORTS_FOLDER_ID=optional-reports-folder-id

# Telegram Bot Configuration (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Web Server Configuration
PORT=5000
FLASK_ENV=production
WEB_SECRET_KEY=generate-a-secure-random-key-here
IC_STAFF_PASSWORD=set-a-secure-password-here

# RAG/Knowledge Configuration (optional)
KNOWLEDGE_DIR=./knowledge
CHROMA_PERSIST_DIR=./chroma_store

# Chat Configuration (optional)
CHAT_USE_REACT_AGENT=0
